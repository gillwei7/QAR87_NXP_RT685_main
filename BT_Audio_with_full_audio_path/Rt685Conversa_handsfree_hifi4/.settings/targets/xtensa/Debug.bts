<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<BuildTarget tool="xtensa" version="1.0">
    <BuildSettings>
        <BaseSettings path="project">
            <PreprocessorOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>Includes</key>
                        <value flag="-I" inheritance="donotinherit">
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/board}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/component/lists}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/component/serial_manager}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/component/uart}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/drivers}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/MIMXRT685S}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/source}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/utilities}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/NatureDspLibary/include}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/ConversaVitEap}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/nxp_utilities_public}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/hifi4_nn}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/ConversaVitEap/tuning_files}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/ConversaVitEap/models}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/CadenceSRC}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/CadenceCommon}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/CadenceOpusDec}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/CadenceSbcDec}</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
                <KeyValueListMapOptions>
                    <KeyValueListMapEntry>
                        <key>Defines</key>
                        <value flag="-D" inheritance="donotinherit">
                            <ListEntry key="DEBUG" value=""/>
                            <ListEntry key="SDK_DEBUGCONSOLE" value="1"/>
                            <ListEntry key="SERIAL_PORT_TYPE_UART=1" value=""/>
                            <ListEntry key="DEBUG_CONSOLE_RX_ENABLE" value="0"/>
                            <ListEntry key="CPU_MIMXRT685SFVKB_dsp" value=""/>
                            <ListEntry key="HIFI4" value=""/>
                            <ListEntry key="WORKSPACE_DIRECTORY" value="&quot;${unixpath:${workspace_loc}}&quot;"/>
                            <ListEntry key="RDSP_USES_IEEE754_CODE" value="1"/>
                            <ListEntry key="RT600" value="1"/>
                            <ListEntry key="CORE_DSP" value=""/>
                            <ListEntry key="PRINTF_ADVANCED_ENABLE" value="0"/>
                            <ListEntry key="PRINTF_FLOAT_ENABLE" value="0"/>
                        </value>
                    </KeyValueListMapEntry>
                </KeyValueListMapOptions>
            </PreprocessorOptions>
            <CompilerOptions>
                <SingleFlagMapOptions>
                    <SingleFlagMapEntry>
                        <key>WarningSetting</key>
                        <value flag="-Wall" use="true"/>
                    </SingleFlagMapEntry>
                    <SingleFlagMapEntry>
                        <key>SupportCPPException</key>
                        <value flag="-fexceptions" use="true"/>
                    </SingleFlagMapEntry>
                    <SingleFlagMapEntry>
                        <key>CompilerEnableLongCall</key>
                        <value flag="-mlongcalls" use="true"/>
                    </SingleFlagMapEntry>
                </SingleFlagMapOptions>
                <FlagValueMapOptions>
                    <FlagValueMapEntry>
                        <key>Debug</key>
                        <value level="-3" flag="-g" use="true"/>
                    </FlagValueMapEntry>
                </FlagValueMapOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>CompilerAdditionalOptions</key>
                        <value flag="" inheritance="append">
                            <ListEntry>-Wno-missing-braces&#13;
-fmessage-length=0&#13;
-mlongcalls</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
            </CompilerOptions>
            <AssemblerOptions>
                <SingleFlagMapOptions>
                    <SingleFlagMapEntry>
                        <key>AssemblerIncludeDebug</key>
                        <value flag="--gdwarf-2" use="true"/>
                    </SingleFlagMapEntry>
                </SingleFlagMapOptions>
            </AssemblerOptions>
            <LinkerOptions>
                <BooleanMapOptions>
                    <BooleanMapEntry>
                        <key>GenerateMapFile</key>
                        <value selected="true"/>
                    </BooleanMapEntry>
                </BooleanMapOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>LibrarySearchPath</key>
                        <value flag="-L" inheritance="prepend">
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/NatureDspLibary}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/hifi4_nn}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/CadenceCommon}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685Conversa_handsfree_hifi4/ConversaVitEap}</ListEntry>
                        </value>
                    </StringListMapEntry>
                    <StringListMapEntry>
                        <key>LinkerAdditionalOptions</key>
                        <value flag="" inheritance="append">
                            <ListEntry>--orphan-handling=place&#13;
--gc-sections&#13;
--cref&#13;
--sort-section=alignment</ListEntry>
                        </value>
                    </StringListMapEntry>
                    <StringListMapEntry>
                        <key>Libraries</key>
                        <value flag="-l" inheritance="prepend">
                            <ListEntry>NXP_EAP16_RT685Hifi4</ListEntry>
                            <ListEntry>NXP_Conversa_RT685HiFi4</ListEntry>
                            <ListEntry>VIT_v6.6.0_EngineeringRelease</ListEntry>
                            <ListEntry>naturedsp</ListEntry>
                            <ListEntry>xa_asrc_src_pp</ListEntry>
                            <ListEntry>xa_opus_dec</ListEntry>
                            <ListEntry>xa_sbc_dec</ListEntry>
                            <ListEntry>xa_nn</ListEntry>
                            <ListEntry>xos</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
                <LinkerSupport custom="true" key="-mlsp=" value="..\..\..\LinkDscrFiles\min-rt"/>
            </LinkerOptions>
        </BaseSettings>
    </BuildSettings>
</BuildTarget>
