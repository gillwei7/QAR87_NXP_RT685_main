<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<BuildTarget tool="xtensa" version="1.0">
    <BuildSettings>
        <BaseSettings path="project">
            <PreprocessorOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>Includes</key>
                        <value flag="-I" inheritance="donotinherit">
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/board}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/component/lists}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/component/serial_manager}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/component/uart}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/drivers}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/MIMXRT685S}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/source}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/utilities}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/NatureDspLibary/include}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/CadenceSRC}</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
                <KeyValueListMapOptions>
                    <KeyValueListMapEntry>
                        <key>Defines</key>
                        <value flag="-D" inheritance="donotinherit">
                            <ListEntry key="DEBUG" value=""/>
                            <ListEntry key="SDK_DEBUGCONSOLE" value="1"/>
                            <ListEntry key="SERIAL_PORT_TYPE_UART=1" value=""/>
                            <ListEntry key="DEBUG_CONSOLE_RX_ENABLE" value="0"/>
                            <ListEntry key="CPU_MIMXRT685SFVKB_dsp" value=""/>
                            <ListEntry key="HIFI4" value=""/>
                            <ListEntry key="WORKSPACE_DIRECTORY" value="&quot;${unixpath:${workspace_loc}}&quot;"/>
                            <ListEntry key="RDSP_USES_IEEE754_CODE" value="1"/>
                            <ListEntry key="RT600" value="1"/>
                            <ListEntry key="RDSP_ENABLE_PRINTF" value="1"/>
                        </value>
                    </KeyValueListMapEntry>
                </KeyValueListMapOptions>
            </PreprocessorOptions>
            <CompilerOptions>
                <SingleFlagMapOptions>
                    <SingleFlagMapEntry>
                        <key>WarningSetting</key>
                        <value flag="-Wall" use="true"/>
                    </SingleFlagMapEntry>
                    <SingleFlagMapEntry>
                        <key>SupportCPPException</key>
                        <value flag="-fexceptions" use="true"/>
                    </SingleFlagMapEntry>
                    <SingleFlagMapEntry>
                        <key>CompilerEnableLongCall</key>
                        <value flag="-mlongcalls" use="true"/>
                    </SingleFlagMapEntry>
                </SingleFlagMapOptions>
                <FlagValueMapOptions>
                    <FlagValueMapEntry>
                        <key>Debug</key>
                        <value level="-3" flag="-g" use="true"/>
                    </FlagValueMapEntry>
                </FlagValueMapOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>CompilerAdditionalOptions</key>
                        <value flag="" inheritance="append">
                            <ListEntry>-Wno-missing-braces&#13;
-fmessage-length=0&#13;
-mlongcalls</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
            </CompilerOptions>
            <AssemblerOptions>
                <SingleFlagMapOptions>
                    <SingleFlagMapEntry>
                        <key>AssemblerIncludeDebug</key>
                        <value flag="--gdwarf-2" use="true"/>
                    </SingleFlagMapEntry>
                </SingleFlagMapOptions>
            </AssemblerOptions>
            <LinkerOptions>
                <BooleanMapOptions>
                    <BooleanMapEntry>
                        <key>CreateMinsize</key>
                        <value selected="true"/>
                    </BooleanMapEntry>
                    <BooleanMapEntry>
                        <key>GenerateMapFile</key>
                        <value selected="true"/>
                    </BooleanMapEntry>
                </BooleanMapOptions>
                <StringListMapOptions>
                    <StringListMapEntry>
                        <key>LibrarySearchPath</key>
                        <value flag="-L" inheritance="prepend">
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/NatureDspLibary}</ListEntry>
                            <ListEntry>${workspace_loc:Rt685_UsbAudio_DspPrg/CadenceSRC}</ListEntry>
                        </value>
                    </StringListMapEntry>
                    <StringListMapEntry>
                        <key>LinkerAdditionalOptions</key>
                        <value flag="" inheritance="append">
                            <ListEntry>--orphan-handling=place</ListEntry>
                        </value>
                    </StringListMapEntry>
                    <StringListMapEntry>
                        <key>Libraries</key>
                        <value flag="-l" inheritance="prepend">
                            <ListEntry>xos</ListEntry>
                            <ListEntry>naturedsp</ListEntry>
                            <ListEntry>xa_asrc_src_pp</ListEntry>
                        </value>
                    </StringListMapEntry>
                </StringListMapOptions>
                <LinkerSupport custom="true" key="-mlsp=" value="..\..\..\LinkDscrFiles\min-rt"/>
            </LinkerOptions>
        </BaseSettings>
    </BuildSettings>
</BuildTarget>
